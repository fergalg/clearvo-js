{
  "name": "@clearvo/cli",
  "version": "0.1.0",
  "description": "CLI for the Clearvo tax compliance API — submit invoices, calculate tax, validate tax numbers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clearvo": "dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "https://github.com/fergalg/clearvo-js.git", "directory": "packages/cli" },
  "homepage": "https://clearvo.io/docs",
  "keywords": ["clearvo", "tax", "einvoicing", "cli", "compliance"]
}
