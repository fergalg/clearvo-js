{
  "name": "@clearvo/mcp",
  "version": "0.2.1",
  "description": "MCP server for Clearvo — submit invoices, calculate tax, validate tax numbers via Claude Code, Cursor, or any MCP-compatible AI tool",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clearvo-mcp": "dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "https://github.com/fergalg/clearvo-js.git", "directory": "packages/mcp" },
  "homepage": "https://clearvo.io/docs/claude-code",
  "keywords": ["clearvo", "mcp", "tax", "einvoicing", "claude", "cursor", "ai"]
}
